---
import CommonHead from "../components/CommonHead.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";

import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

type Props = CollectionEntry<"blog">["data"];

const {
	title,
	description = "Personal blog of Michael Mandic",
	pubDate,
	updatedDate,
	heroImage,
} = Astro.props;
const titleId = title.replace(/\s+/g, "-").toLowerCase();
---

<!doctype html>
<html lang="en">
	<head>
		<CommonHead />
		<title>
			{`${title} - Michael Mandic Blog`}
		</title>
		<meta name="description" content={description} />
	</head>
	<body
		x-data="{ open: false }"
		x-init="$watch('open', value => { document.body.classList.toggle('overflow-hidden', value) })"
	>
		<NavBar />

		<main>
			<a href="/blog" class="small italic no-underline mb-2 hover:mb-1"
				>← all posts</a
			>
			<article>
				<div>
					{
						heroImage && (
							<Image
								width={1020}
								height={510}
								src={heroImage}
								alt=""
							/>
						)
					}
				</div>
				<div>
					<div>
						{
							updatedDate && (
								<div class="last-updated-on">
									Last updated on{" "}
									<FormattedDate date={updatedDate} />
								</div>
							)
						}
						<h1>{title}</h1>
						<p class="small mb-8">
							<FormattedDate date={pubDate} />
						</p>
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
