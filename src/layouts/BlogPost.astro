---
import CommonHead from "../components/CommonHead.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import ShareLinks from "../components/ShareLinks.astro";

import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

type Props = CollectionEntry<"blog">["data"];

const {
	title,
	description = "Personal blog of Michael Mandic",
	pubDate,
	updatedDate,
	heroImage,
} = Astro.props;
const titleId = title.replace(/\s+/g, "-").toLowerCase();

const url = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<CommonHead />
		<title>
			{`${title} - Michael Mandic Blog`}
		</title>
		<meta name="description" content={description} />
		<!-- open graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={url} />
		<meta property="og:type" content="article" />
	</head>
	<body>
		<div class="max-w-2xl w-full">
			<NavBar />
			<main>
				<article>
					<div>
						{
							heroImage && (
								<Image
									width={1020}
									height={510}
									src={heroImage}
									alt=""
								/>
							)
						}
					</div>
					<div class="mb-4 text-faint">
						<a href="/blog" class="italic hidden-underline"
							>← all posts</a
						>
					</div>
					<div>
						<div class="mb-8">
							<h1 class="my-0">{title}</h1>
							<div class="text-faint my-4">
								<FormattedDate date={pubDate} />
							</div>
							{
								updatedDate && (
									<div class="text-faint my-4">
										Last updated on{" "}
										<FormattedDate date={updatedDate} />
									</div>
								)
							}
							<ShareLinks title={Astro.props.title} url={url} />
						</div>
						<slot />
					</div>
				</article>
			</main>
			<Footer />
		</div>
	</body>
</html>
