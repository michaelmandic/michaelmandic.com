---
import { Menu, X } from "@lucide/astro";

const path = Astro.url.pathname;

const links = [
    { name: "Home", href: "/" },
    { name: "Blog", href: "/blog" },
    { name: "Links", href: "/links" },
    { name: "About", href: "/about" },
    { name: "Contact", href: "/contact" },
];

function navLink(href: string) {
    return path === href || path.startsWith(href + "/")
        ? "text-blackwhite hover:text-main-green active:text-main-green underline"
        : "";
}
---

<header id="top" class="max-w-2xl mb-16 pt-12 text-faint hidden-underline">
    <div
        class="gap-3 px-6 relative z-50 flex justify-center sm:justify-start sm:items-center flex-col sm:flex-row"
    >
        <nav>
            <ul class="flex gap-x-3 gap-y-0 flex-wrap">
                {
                    links.map((link) => (
                        <li>
                            <a
                                href={link.href}
                                class={navLink(link.href)}
                                aria-current={
                                    path === link.href ? "page" : undefined
                                }
                            >
                                {link.name}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>
    </div>
</header>
